  # # # # #  
  # # # # #  

  Solución del Ejercicio Propuesto 
'''
import math

def cuadrado(n):
    print("\n--- CUADRADO ---")
    for i in range(n):
        for j in range(n):
            print("#", end=" ")
        print()

def rectangulo(n):
    print(f"\n--- RECTÁNGULO ({n}x{2*n}) ---")
    for i in range(n):
        for j in range(2*n):
            print("#", end=" ")
        print()

def triangulo(n):
    print("\n--- TRIÁNGULO ---")
    for i in range(1, n+1):
        for j in range(i):
            print("#", end=" ")
        print()

def circulo(r):
    print(f"\n--- CÍRCULO (Radio {r}) ---")
    for i in range(-r, r+1):
        for j in range(-r, r+1):
            if i**2 + j**2 <= r**2:
                print("#", end=" ")
            else:
                print(" ", end=" ")
        print()

def pentagono(n):
    print("\n--- PENTÁGONO ---")
    # Parte superior (triángulo)
    for i in range(n):
        print(" " * (n-i) + "# " * (i+1))
    # Parte inferior (rectángulo/trapecio)
    for i in range(n):
        print("# " * (n+2))

def menu():
    print("\nSeleccione la figura a imprimir:")
    print("1. Triángulo Rectángulo")
    print("2. Cuadrado")
    print("3. Rectángulo")
    print("4. Círculo")
    print("5. Pentágono")

    opcion = int(input("Ingrese el número de la figura: "))
    tamaño = int(input("Ingrese el tamaño para sus figuras: "))

    if opcion == 1:
        triangulo(tamaño)
    elif opcion == 2:
        cuadrado(tamaño)
    elif opcion == 3:
        rectangulo(tamaño)
    elif opcion == 4:
        circulo(tamaño)
    elif opcion == 5:
        pentagono(tamaño)
    else:
        print("Opción inválida.")

# Programa principal
menu()
